@startuml
title Sequencia - Ronda Completa (Estado Atual)

participant "Game" as Game
participant "RoundSetupState" as Setup
participant "RoundPlayingState" as Playing
participant "Trick" as Trick
participant "BotStrategy" as Bot
participant "EventBus" as Bus
participant "WebSocketObserver" as WS
participant "EventPersistenceObserver" as Persist

== Setup da ronda ==
Game -> Setup : Enter()
Setup -> Setup : criar deck + shuffle
Setup -> Bus : TRUMP_REVEALED

loop distribuir 10 cartas por jogador
  Setup -> Bus : CARD_DEALT
end

Setup -> Bus : ROUND_STARTED
Setup -> Playing : Enter()

== Inicio de vaza ==
Playing -> Trick : NewTrick(leader aleatorio)
Playing -> Bus : TRICK_STARTED
Playing -> Bus : TURN_CHANGED(leader)

== Jogadas ==
loop ate Trick completa
  alt jogador humano envia comando
    Game -> Trick : AddPlay(play)
  else proximo jogador e bot
    Playing -> Bot : ChooseCard(hand,leadSuit,rules)
    Bot --> Playing : card
    Playing -> Trick : AddPlay(play)
  end

  Playing -> Bus : CARD_PLAYED
  opt trick nao terminou
    Playing -> Bus : TURN_CHANGED(nextPlayer)
  end
end

== Fecho da vaza ==
Playing -> Trick : WinningPlayer() + TrickPoints()
Playing -> Bus : TRICK_ENDED

alt ronda terminou (maos vazias)
  Playing -> Bus : ROUND_ENDED
else nova vaza
  Playing -> Trick : StartNewTrick(winner)
  Playing -> Bus : TRICK_STARTED
  Playing -> Bus : TURN_CHANGED(winner)
end

== Fan-out de eventos ==
loop para cada evento publicado
  Bus -> WS : Update(event)
  WS -> WS : broadcast para roomId
  Bus -> Persist : Update(event)
end

@enduml
