' interface RoomRepository
' interface UserRepository
' interface UserStatsRepository
' interface GameRepository
' interface EventRepository

interface ICommand {
  +Execute(room): error
}

class PlayCardCommand implements ICommand {
  +Execute(room): error
}

class ChangeBotStrategyCommand implements ICommand {
  +Execute(room): error
}

' ========================
' Infraestrutura: WebSockets
' ========================
class Hub {
  +CreateRoomHub(room): RoomHub
  +GetRoomHub(roomID): RoomHub
  +GetRoom(roomID): Room
  +DeleteRoom(roomID): void
  +AddClient(roomID, client): void
  +RemoveClient(roomID, client): void
  +BroadcastToRoom(roomID, payload): void
}

class RoomHub {
  +GetRoom(): Room
  +AddClient(client): void
  +RemoveClient(client): bool
  +IsEmpty(): bool
  +Broadcast(payload): void
}

class Client {
  +Enqueue(payload): bool
  +Close(): void
  +ReadPump(): void
  +WritePump(): void
}

class CommandContext {
  +PlayerID: string
  +RoomID: string
  +Client: Client
}

class CommandDispatcher {
  +Register(messageType, handler): void
  +Dispatch(ctx, msg): error
  +HandleMessage(client, raw): void
}

class Handler {
  +Hub: Hub
  +Dispatcher: CommandDispatcher
  +ServeHTTP(w, r): void
}

class WebSocketObserver {
  +Update(event): void
}

class ClientMessage {
  +Type: string
  +Payload: json
}

class ServerMessage {
  +Type: string
  +Success: bool
  +Error: string
}

' ========================
' Infraestrutura: Eventos
' ========================
class EventDispatcher {
  +Register(messageType, handler): void
  +Dispatch(event): error
  +HandleMessage(event): void
}

class EventPersistanceObserver {
  +Update(event): void
}

' ========================
' Relacoes
' ========================

' --- Dominio ---
Room "1" -- "0..1" Game
Room "1" -- "1..4" Player
Game "1" -- "2" Team
Team "1" -- "1..2" Player
Player "1" -- "1" Hand
Hand "1" -- "0..*" Card
Round "1" -- "1" Trick
Trick "1" -- "0..4" Play
Play "1" -- "1" Card
Trick "1" -- "1" TurnOrder
Game "1" -- "1" Round
Game "1" -- "0..*" Event
Room "1" -- "1" EventBus
Game "1" -- "1" EventBus

Game --> IGameState
Round --> IRoundState
Game --> IGameScoringStrategy
Round --> IRoundRuleStrategy
Trick --> ITrickRuleStrategy
Trick --> ITrickScoringStrategy
Round --> IBotStrategy
Room --> IBotStrategy

' RoomService --> RoomRepository
' RoomService --> UserRepository
' RoomService --> GameRepository
' RoomService --> EventService

' UserService --> UserRepository
' UserService --> UserStatsRepository
' UserStatsService --> UserStatsRepository
' GameService --> GameRepository
' EventService --> EventRepository

PlayCardCommand --> Room
ChangeBotStrategyCommand --> Room

' --- Aplicacao ---


' --- Infraestrutura WebSocket ---
Hub "1" *-- "0..*" RoomHub
RoomHub "1" *-- "0..*" Client
Client --> CommandDispatcher
Handler --> Hub
Handler --> CommandDispatcher

WebSocketObserver ..|> Observer
WebSocketObserver --> Hub
EventBus o-- WebSocketObserver

' --- Infraestrutura Eventos ---
EventPersistanceObserver ..|> Observer
EventPersistanceObserver --> EventDispatcher
EventBus o-- EventPersistanceObserver

@enduml
