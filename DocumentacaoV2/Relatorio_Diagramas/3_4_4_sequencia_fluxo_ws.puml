@startuml
title Sequencia - Fluxo de Comando e Broadcast (WebSocket Atual)

actor "Jogador" as Player
participant "WebSocketService" as FE_WS
participant "Client" as Client
participant "CommandDispatcher" as Dispatcher
participant "PlayCardHandler" as Handler
participant "Game" as Game
participant "EventBus" as Bus
participant "WebSocketObserver" as WSObs
participant "EventPersistenceObserver" as Persist
participant "Outros Clientes" as Others

Player -> FE_WS : send(play_card, cardId)
FE_WS -> Client : frame JSON
Client -> Dispatcher : HandleMessage(raw)
Dispatcher -> Handler : Dispatch(play_card)
Handler -> Game : PlayCard(playerId, cardId)

alt erro de validacao
  Game --> Handler : error
  Handler --> Dispatcher : error
  Dispatcher -> Client : ServerMessage{success:false,error}
  Client --> FE_WS : resposta erro
else sucesso
  Handler --> Dispatcher : ok

  loop eventos de dominio gerados
    Game -> Bus : Publish(event)
    Bus -> WSObs : Update(event)
    WSObs -> Others : broadcast para a sala

    Bus -> Persist : Update(event)
    Persist -> Persist : save quando gameId != vazio
  end

  Dispatcher -> Client : ServerMessage{success:true}
  Client --> FE_WS : comando confirmado
end

@enduml
