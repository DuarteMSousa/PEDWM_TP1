@startuml
title 2.2 Arquitetura Conceptual do Sistema

skinparam shadowing false
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam defaultTextAlignment center

actor "Jogador" as Player

package "Cliente" {
  component "Frontend\n(Flutter)" as FE
}

package "Servidor" {
  component "API GraphQL\n(Queries + Mutations)" as GQL
  component "Canal WebSocket\n(Eventos em Tempo Real)" as WS
  component "Dominio do Jogo\n(Room, Game, Round, Trick)" as Domain
}

database "PostgreSQL" as DB

Player --> FE : Interacao UI

FE --> GQL : HTTP\nOperacoes estruturadas
FE <--> WS : WebSocket\nEventos em tempo real

GQL --> Domain : Comandos e consultas
WS --> Domain : Comandos realtime
Domain --> WS : Publicacao de eventos

Domain <--> DB : Persistencia\n(users, rooms, games, events)

@enduml
