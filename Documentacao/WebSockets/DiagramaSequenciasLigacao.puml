@startuml
title Sequência - Ligação WebSocket e limpeza de recursos

actor Browser as "Navegador"
participant "WebSocketHandler" as Handler
participant "Hub" as Hub
participant "RoomHub" as RoomHub
participant "Client" as Client

Navegador -> Handler : GET /ws?roomId=...&playerId=...
Handler -> Handler : roomID = query OU "lobby"
Handler -> Handler : playerID = query OU remoteAddr
Handler -> Handler : Upgrade (inclui CheckOrigin)

alt upgrade com sucesso
  Handler -> Client : NewClient(playerID, roomID, conn, hub)
  Handler -> Hub : AddClient(roomID, client)
  Hub -> Hub : GetOrCreateRoom(roomID)
  Hub -> RoomHub : AddClient(client)

  par WritePump
    Handler -> Client : go WritePump()
  else ReadPump
    Handler -> Client : go ReadPump()
  end

  Handler --> Navegador : ligação WebSocket ativa
else falha no upgrade
  Handler --> Navegador : rejeitar / fechar ligação
end

== Caminho de desconexão ==
Client -> Hub : RemoveClient(roomID, client)
Hub -> RoomHub : RemoveClient(client)

alt sala ficou vazia
  Hub -> Hub : remover roomID
end

@enduml