@startuml
title Sueca - Diagrama de Classes Atualizado (Domain + Patterns)

skinparam classAttributeIconSize 0

interface Event {
  +id:ID
  +gameId: string
  +timestamp: datetime
  +type: EventType
}

class GameCreatedEvent implements Event {
  +type: GAME_CREATED
  +creatorId: string
  +settings: GameSettings
}

class PlayerJoinedEvent implements Event {
  +type: PLAYER_JOINED
  +playerId: string
  +name: string
  +slot: int
}

class PlayerLeftEvent implements Event {
  +type: PLAYER_LEFT
  +playerId: string
}

class GameStartedEvent implements Event {
  +type: GAME_STARTED
}

class RoundStartedEvent implements Event {
  +type: ROUND_STARTED
  +roundNumber: int
  +dealerId: string
}

class TrumpRevealedEvent implements Event {
  +type: TRUMP_REVEALED
  +card: Card
  +suit: Suit
}

class CardDealtEvent implements Event {
  +type: CARD_DEALT
  +playerId: string
  +cards: Card[]
}

class CardPlayedEvent implements Event {
  +type: CARD_PLAYED
  +playerId: string
  +card: Card
}

class TrickEndedEvent implements Event {
  +type: TRICK_ENDED
  +winnerId: string
  +points: int
}

class RoundEndedEvent implements Event {
  +type: ROUND_ENDED
  +teamAScore: int
  +teamBScore: int
  +winnerTeam: string
}

class GameEndedEvent implements Event {
  +type: GAME_ENDED
  +finalScores: Map<string, int>
  +winnerTeam: string
}

'========================
' Enums / Value Objects
'========================
enum Suit {
  HEARTS
  SPADES
  DIAMONDS
  CLUBS
}

enum Rank {
  A
  SEVEN
  K
  J
  Q
  SIX
  FIVE
  FOUR
  THREE
  TWO
}

interface ICommand {
  void Execute(Game game);
}

interface EnterGameCommand implements ICommand {
  PlayerID: string

  void Execute(Game game);
}


interface PlayCardCommand implements ICommand {
  PlayerID: string
  CardID: string

  void Execute(Game game);
}

interface LeaveGameCommand implements ICommand {
  PlayerID: string

  void Execute(Game game);
}

interface IGameState{
  void Enter(Game game);
  void Update(Game game);
}

class GameStartingState implements IGameState {
  +Enter(game: Game): void
  +Update(game: Game): void
}

class GamePlayingState implements IGameState {
  +Enter(game: Game): void
  +Update(game: Game): void
}

class GameEndedState implements IGameState {
  +Enter(game: Game): void
  +Update(game: Game): void
}

interface IRoundState{
  void Enter(Round Round);
  void Update(Round Round);
}

class RoundSetupState implements IRoundState {
  +Enter(Round Round): void
  +Update(Round Round): void
}

class RoundPlayingState implements IRoundState {
  +Enter(Round Round): void
  +Update(Round Round): void
}

class RoundScoringState implements IRoundState {
  +Enter(Round Round): void
  +Update(Round Round): void
}

class DeckFactory {
  +CreateSuecaDeck(): Deck
}

class Deck {
  +Cards: Card[*]
  +Shuffle(): void
  +Draw(): (Card, error)
  + Remaining() int
  + IsEmpty()
}

class Hand{
  - Cards: Card[]
  + AddCard(card)
  + RemoveCard(card)
  + HasSuit(suit)
  + PlayableCards()
}

class GameFactory {
  +CreateGame(room: Room): Game
}


enum RoomStatus {
  OPEN
  IN_GAME
  CLOSED
}

'========================
' Core Domain
'========================
class Card {
  +Suit: Suit
  +Rank: Rank
}

class Player {
  +ID: string
  +Name: string
  +Type: PlayerType
}

class Bot extends Player {
  +BotStrategy: BotPlayStrategy
  +ChooseCard(Hand hand,leadSuit: Suit, trump: Suit): Card
}

class Team {
  +ID: string
  +Players: string[2]
  +GameScore: int
  +AddGamePoints(points: int)
}

class Play {
  +PlayerID: string
  +Card: Card
}

class Trick {
  +LeaderID: string
  +LeadSuit: Suit
  +Plays: Play[*]
  +AddPlay(play: Play): error
  +IsEmpty(): bool
  +IsComplete(): bool
  +HasPlayed(playerID: string): bool
  +Reset(newLeaderID: string): void
}

class TurnOrder {
  +Players(): string[*] ou queue
  +Contains(playerID: string): bool
  +Next(currentPlayerID: string): string
  +HasNext(): bool
}

class Round {
  +TricksPlayed: int
  +CurrentTrick: Trick
  +Hands: map<string, Hand>
  +Points: map<string, int>
  +IsFinished(): bool
  +StartNewTrick(leaderID: string): void
}

class Game {
  +ID: string
  +Teams: map<string, Team>

  +GameScoringStrategy: IGameScoringStrategy
  +EventBus: EventBus
  +Events: Event[*]
  +Start(): error
  +PlayCard(playerID: string, cardID: string): error
  +Validate(): error
}

class Room {
  +ID: string
  +HostId: string
  +Players: map<string, Player>
  +Status: RoomStatus
  +GameID: string
  +CreatedAt: datetime

  +AddPlayer(p: Player): error
  +RemovePlayer(playerID: string): error
  +CanStartGame(): bool
  +StartGame(gameID: string): error
  +Close(): void
}

'========================
' Strategy Pattern
'========================
interface RoundRuleStrategy {
  +Winner(Round round): string
  +HasEnded(Round round): bool
}

interface TrickRuleStrategy {
  +Winner(Trick trick): string
  +HasEnded(Round round): bool
  +ValidatePlay(Trick trick,Play play): error
}

interface TrickScoringStrategy {
  +CardPoints(card: Card): int
  +TrickPoints(plays: Play[*]): int
}

interface BotStrategy {
  +ChooseCard(hand: Card[*], leadSuit: Suit, trump: Suit): Card
}

class SuecaTrickRules
class SuecaTrickScoring
class EasySuecaBotStrategy
class HardSuecaBotStrategy

TrickRuleStrategy <|.. SuecaTrickRules
TrickScoringStrategy  <|.. SuecaTrickScoring
BotStrategy  <|.. EasySuecaBotStrategy
BotStrategy  <|.. HardSuecaBotStrategy
BotStrategy <|.. Bot

'========================
' Observer Pattern
'========================
enum EventType {
  GAME_CREATED
  PLAYER_JOINED
  PLAYER_LEFT
  GAME_STARTED
  ROUND_STARTED
  TRICK_STARTED
  TRUMP_REVEALED
  CARD_DEALT
  CARD_PLAYED
  TRICK_ENDED
  ROUND_ENDED
  GAME_ENDED
}

interface Observer {
  +Update(e: Event): void
}

interface Subject {
  +Subscribe(o: Observer): void
  +Unsubscribe(o: Observer): void
  +Notify(e: Event): void
}

class EventBus implements Subject {
  +Subscribe(o: Observer): void
  +Unsubscribe(o: Observer): void
  +Notify(e: Event): void
}

class WebSocketObserver
class LoggerObserver

Observer <|.. WebSocketObserver
Observer <|.. LoggerObserver

EventBus o-- Observer : notifies >
Game o-- EventBus

'========================
' Associations
'========================
Team "1" -- "2" Player : players
Play "*" -- "1" Card
Hand "1" -- "*" Card
Deck "1" -- "*" Card
Trick "1" -- "*" Play
Round "1" -- "1" Trick : currentTrick
Game "1" -- "*" Team
Trick "1" -- "1" TurnOrder
Game "1" -- "1" Round
Game "1" -- "*" Event : events
Room "1" -- "*" Player
Room "1" -- "0..1" Game : gameId
Round  -- RoundRuleStrategy
Trick -- TrickRuleStrategy
Trick -- TrickScoringStrategy
Game -- IGameState
Round -- IRoundState
Round -- Deck
Round -- Hand

Suit <|-- Card
Rank <|-- Card

RoomStatus <|-- Room

EventType <|-- Event
@enduml