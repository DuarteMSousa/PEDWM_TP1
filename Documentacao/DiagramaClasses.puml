interface PlayCardCommand implements ICommand {
  PlayerID: string
  CardID: string

  void Execute(Game game);
}

interface LeaveGameCommand implements ICommand {
  PlayerID: string

  void Execute(Game game);
}

interface IGameState{
  void Enter(Game game);
  void Update(Game game);
}

class ShuffleCardsState implements IGameState {
  +Enter(game: Game): void
  +Update(game: Game): void
}

' class ChooseTrumpCardState implements IGameState {
'   +Enter(game: Game): void
'   +Update(game: Game): void
' }

class RevealTrumpState implements IGameState {
  +Enter(game: Game): void
  +Update(game: Game): void
}

class DealCardsState implements IGameState {
  +Enter(game: Game): void
  +Update(game: Game): void
}

class PlayTricksState implements IGameState {
  +Enter(game: Game): void
  +Update(game: Game): void
}

class EndTrickState implements IGameState {
  +Enter(game: Game): void
  +Update(game: Game): void
}

class EndGameState implements IGameState {
  +Enter(game: Game): void
  +Update(game: Game): void
}

class DeckFactory {
  +CreateDeck(): Card[*]
}


class GameFactory {
  +CreateGame(room: Room): Game
}




enum RoomStatus {
  OPEN
  IN_GAME
  CLOSED
}

'========================
' Core Domain
'========================
class Card {
  +ID: string
  +Suit: Suit
  +Rank: Rank
  +IsTrump(trump: Suit): bool
}

class Player {
  +ID: string
  +Name: string
  +Type: PlayerType
  +TeamID: string
  +Hand: Card[*]
  +RemoveCard(cardID: string): (Card, bool)
}

class Bot extends Player {
  +BotStrategy: BotPlayStrategy
  +ChooseCard(leadSuit: Suit, trump: Suit): Card
}

class Team {
  +ID: string
  +Players: string[2]
  +GameScore: int
  +RoundScore: int
  +AddPoints(points: int)
}

class Play {
  +PlayerID: string
  +Card: Card
}

class Trick {
  +LeaderID: string
  +LeadSuit: Suit
  +Plays: Play[*]
  +AddPlay(play: Play): error
  +IsEmpty(): bool
  +IsComplete(): bool
  +HasPlayed(playerID: string): bool
  +Reset(newLeaderID: string): void
}

class TurnOrder {
  +Players(): string[*]
  +Contains(playerID: string): bool
  +Next(currentPlayerID: string): string
}

class Round {
  +TrumpSuit: Suit
  +TricksPlayed: int
  +CurrentTrick: Trick
  +IsFinished(): bool
  +StartNewTrick(leaderID: string): void
  +IncrementTrick(): void
}

class Game {
  +ID: string
  +Players: map<string, Player>
  +Teams: map<string, Team>
  +Order: TurnOrder
  +TurnPlayer: string
  +Round: Round
  +State: GameState

  +DeckFactory: DeckFactory
  +RuleStrategy: TrickRuleStrategy
  +ScoringStrategy: ScoringStrategy
  +EventBus: EventBus
  +Events: Event[*]
  +Start(): error
  +PlayCard(playerID: string, cardID: string): error
  +Validate(): error
}

class Room {
  +ID: string
  +HostID: string
  +Players: map<string, Player>
  +Status: RoomStatus
  +GameID: string
  +CreatedAt: datetime

  +AddPlayer(p: Player): error
  +RemovePlayer(playerID: string): error
  +CanStartGame(): bool
  +StartGame(gameID: string): error
  +Close(): void
}

'========================
' Strategy Pattern
'========================
interface TrickRuleStrategy {
  +Winner(trump: Suit, plays: Play[*]): string
  +ValidatePlay(hand: Card[*], leadSuit: Suit, card: Card): error
}

interface ScoringStrategy {
  +CardPoints(card: Card): int
  +TrickPoints(plays: Play[*]): int
}

interface BotStrategy {
  +ChooseCard(hand: Card[*], leadSuit: Suit, trump: Suit): Card
}

class SuecaTrickRules
class SuecaScoring
class SimpleBotStrategy

TrickRuleStrategy <|.. SuecaTrickRules
ScoringStrategy  <|.. SuecaScoring
BotStrategy  <|.. SimpleBotStrategy
BotStrategy <|.. Bot

'========================
' Observer Pattern
'========================
enum EventType {
  GAME_CREATED
  PLAYER_JOINED
  GAME_STARTED
  CARDS_DEALT
  TRUMP_REVEALED
  TURN_CHANGED
  CARD_PLAYED
  TRICK_ENDED
  SCORE_UPDATED
  ROUND_ENDED
  GAME_ENDED
  ERROR
}

class Event {
  +Type: EventType
  +GameID: string
  +Timestamp: datetime
  +Payload: any
}

interface Observer {
  +Update(e: Event): void
}

interface Subject {
  +Subscribe(o: Observer): void
  +Unsubscribe(o: Observer): void
  +Notify(e: Event): void
}

class EventBus implements Subject {
  +Subscribe(o: Observer): void
  +Unsubscribe(o: Observer): void
  +Notify(e: Event): void
}

class WebSocketObserver
class LoggerObserver

Observer <|.. WebSocketObserver
Observer <|.. LoggerObserver

EventBus o-- Observer : notifies >
Game o-- EventBus

'========================
' Associations
'========================
Player "1" o-- "*" Card : hand
Team "1" -- "2" Player : players
Play "*" --> "1" Card
Trick "1" o-- "*" Play
Round "1" o-- "1" Trick : currentTrick
Game "1" o-- "*" Player
Game "1" o-- "*" Team
Game "1" o-- "1" TurnOrder
Game "1" o-- "1" Round
Game "1" o-- "*" Event : events
Room "1" o-- "*" Player
Room "1" --> "0..1" Game : gameId

Game --> TrickRuleStrategy
Game --> ScoringStrategy
Game --> IGameState

Suit <|-- Card
Rank <|-- Card

RoomStatus <|-- Room

EventType <|-- Event

' TrumpCardOption <|-- ChooseTrumpCardCommand

PlayerType <|-- Player
@enduml