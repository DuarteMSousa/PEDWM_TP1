@startuml
title Sueca - Diagrama de Classes Atualizado (Domain + Patterns)

skinparam classAttributeIconSize 0

'========================
' Event System
' ========================

abstract class Event {
  +id:ID
  +gameId: string
  +timestamp: datetime
  +type: EventType
}

class GameCreatedEvent extends Event {
  +type: GAME_CREATED
  +creatorId: string
  +settings: GameSettings
}

class PlayerJoinedEvent extends Event {
  +type: PLAYER_JOINED
  +playerId: string
  +name: string
  +slot: int
}

class PlayerLeftEvent extends Event {
  +type: PLAYER_LEFT
  +playerId: string
}

class GameStartedEvent extends Event {
  +type: GAME_STARTED
}

class RoundStartedEvent extends Event {
  +type: ROUND_STARTED
  +roundNumber: int
  +dealerId: string
}

class TrumpRevealedEvent extends Event {
  +type: TRUMP_REVEALED
  +card: Card
  +suit: Suit
}

class CardDealtEvent extends Event {
  +type: CARD_DEALT
  +playerId: string
  +cards: Card[]
}

class CardPlayedEvent extends Event {
  +type: CARD_PLAYED
  +playerId: string
  +card: Card
}

class TrickEndedEvent extends Event {
  +type: TRICK_ENDED
  +winnerId: string
  +points: int
}

class RoundEndedEvent extends Event {
  +type: ROUND_ENDED
  +teamAScore: int
  +teamBScore: int
  +winnerTeam: string
}

class GameEndedEvent extends Event {
  +type: GAME_ENDED
  +finalScores: Map<string, int>
  +winnerTeam: string
}

' ========================
' Strategy Pattern Interfaces
' ========================


interface IGameScoringStrategy  {
  +CalculateRoundPoints(round: Round): Map<string, int>
}

class SuecaGameScoringStrategy implements IGameScoringStrategy {
  +CalculateRoundPoints(round: Round): Map<string, int>
}


'========================
' Enums
'========================
enum Suit {
  HEARTS
  SPADES
  DIAMONDS
  CLUBS
}

enum Rank {
  A
  SEVEN
  K
  J
  Q
  SIX
  FIVE
  FOUR
  THREE
  TWO
}

enum RoomStatus {
  OPEN
  IN_GAME
  CLOSED
}

enum EventType {
  GAME_CREATED
  PLAYER_JOINED
  PLAYER_LEFT
  GAME_STARTED
  ROUND_STARTED
  TRICK_STARTED
  TRUMP_REVEALED
  CARD_DEALT
  CARD_PLAYED
  TRICK_ENDED
  ROUND_ENDED
  GAME_ENDED
}

'========================
' Factories
'========================

class DeckFactory {
  +CreateSuecaDeck(): Deck
}

class GameFactory {
  +CreateSuecaGame(room: Room): Game
}

' ========================
' Command Pattern
' ========================

interface ICommand {
  void Execute(Game game);
}

interface EnterGameCommand implements ICommand {
  PlayerID: string

  void Execute(Game game);
}


interface PlayCardCommand implements ICommand {
  PlayerID: string
  CardID: string

  void Execute(Game game);
}

interface LeaveGameCommand implements ICommand {
  PlayerID: string

  void Execute(Game game);
}


interface IGameState{
  void Enter(Game game);
  void Update(Game game);
}

class GameStartingState implements IGameState {
  +Enter(game: Game): void
  +Update(game: Game): void
}

class GamePlayingState implements IGameState {
  +Enter(game: Game): void
  +Update(game: Game): void
}

class GameFinishedState implements IGameState {
  +Enter(game: Game): void
  +Update(game: Game): void
}

interface IRoundState{
  void Enter(Round Round);
  void Update(Round Round);
}

class RoundSetupState implements IRoundState {
  +Enter(Round Round): void
  +Update(Round Round): void
}

class RoundPlayingState implements IRoundState {
  +Enter(Round Round): void
  +Update(Round Round): void
}

class RoundFinishedState implements IRoundState {
  +Enter(Round Round): void
  +Update(Round Round): void
}


class Deck {
  +Cards: Card[*]
  +Shuffle(): void
  +Draw(): (Card, error)
  + Remaining() int
  + IsEmpty()
}

class Hand{
  - Cards: Card[]
  + AddCard(card)
  + RemoveCard(card)
  + HasSuit(suit)
}



'========================
' Core Domain
'========================
class Room {
  +ID: string
  +HostId: string
  +Players: map<string, Player>
  +Status: RoomStatus
  +GameID: string
  +CreatedAt: datetime

  +AddPlayer(p: Player): error
  +RemovePlayer(playerID: string): error
  +CanStartGame(): bool
  +StartGame(gameID: string): error
  +Close(): void
}

class Game {
  +ID: string
  +Teams: map<string, Team>

  +GameScoringStrategy: IGameScoringStrategy
  +EventBus: EventBus
  +Events: Event[*]
  +Start(): error
  +PlayCard(playerID: string, cardID: string): error
  +Validate(): error
}

class Player {
  +ID: string
  +Name: string
  +Type: PlayerType
}

class Bot extends Player {
  +ChooseCard(Hand hand,leadSuit: Suit, trump: Suit): Card
}

class Team {
  +ID: string
  +Players: string[2]
  +GameScore: int
  +AddGamePoints(points: int)
}

class Round {
  +TricksPlayed: int
  +CurrentTrick: Trick
  +Hands: map<string, Hand>
  +Points: map<string, int>
  +IsFinished(): bool
  +StartNewTrick(leaderID: string): void
}

class Card {
  +Suit: Suit
  +Rank: Rank
}

class TurnOrder {
  +Players(): string[*] ou queue
  +Contains(playerID: string): bool
  +Next(currentPlayerID: string): string
  +HasNext(): bool
}

class Trick {
  +LeaderID: string
  +LeadSuit: Suit
  +Plays: Play[*]
  +AddPlay(play: Play): error
  +IsEmpty(): bool
  +IsComplete(): bool
  +HasPlayed(playerID: string): bool
  +Reset(newLeaderID: string): void
}


class Play {
  +PlayerID: string
  +Card: Card
}



'========================
' Strategy Pattern
'========================
interface RoundRuleStrategy {
  +Winner(Round round): string
  +HasEnded(Round round): bool
}

interface TrickRuleStrategy {
  +Winner(Trick trick): string
  +HasEnded(Round round): bool
  +ValidatePlay(Trick trick,Play play): error
}

interface TrickScoringStrategy {
  +CardPoints(card: Card): int
  +TrickPoints(plays: Play[*]): int
}

interface IBotStrategy {
  +ChooseCard(hand: Card[*], leadSuit: Suit, trump: Suit): Card
}

class SuecaTrickRules
class SuecaTrickScoring
class EasySuecaBotStrategy
class HardSuecaBotStrategy

TrickRuleStrategy <|.. SuecaTrickRules
TrickScoringStrategy  <|.. SuecaTrickScoring
IBotStrategy  <|.. EasySuecaBotStrategy
IBotStrategy  <|.. HardSuecaBotStrategy
IBotStrategy <|.. Bot

'========================
' Observer Pattern
'========================

interface Observer {
  +Update(e: Event): void
}

interface Subject {
  +Subscribe(o: Observer): void
  +Unsubscribe(o: Observer): void
  +Notify(e: Event): void
}

class EventBus implements Subject {
  +Subscribe(o: Observer): void
  +Unsubscribe(o: Observer): void
  +Notify(e: Event): void
}

class WebSocketObserver
class LoggerObserver

Observer <|.. WebSocketObserver
Observer <|.. LoggerObserver

EventBus o-- Observer : notifies >
Game o-- EventBus

'========================
' Associations
'========================
Team "1" -- "*" Player
Play "1" -- "1" Card
Hand "1" -- "*" Card
Deck "1" -- "*" Card
Trick "1" -- "0..*" Play
Round "1" -- "1" Trick
Game "1" -- "*" Team
Game "1" -- "1" IBotStrategy
Game "1" -- "1" IGameScoringStrategy
Trick "1" -- "1" TurnOrder
Game "1" -- "1" Round
Room "1" -- "*" Player
Room "1" -- "0..1" Game
Round "1" -- "1" RoundRuleStrategy
Trick "1" -- "1" TrickRuleStrategy
Trick "1" -- "1" TrickScoringStrategy
Game "1" -- "1" IGameState
Round "1" -- "1" IRoundState
Round "1" -- "1" Deck
Round "1" -- "*" Hand
Game "1" -up- "*" Event
@enduml