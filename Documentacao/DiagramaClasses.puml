@startuml
title Sueca - Diagrama de Classes Atualizado (Domain + Patterns)

skinparam classAttributeIconSize 0

'========================
' Enums / Value Objects
'========================
enum Suit {
  HEARTS
  SPADES
  DIAMONDS
  CLUBS
}

enum Rank {
  A
  SEVEN
  K
  J
  Q
  SIX
  FIVE
  FOUR
  THREE
  TWO
}

enum PlayerType {
  HUMAN
  BOT
}

interface ICommand {
  void Execute(Game game);
}

interface EnterGameCommand implements ICommand {
  PlayerID: string

  void Execute(Game game);
}

