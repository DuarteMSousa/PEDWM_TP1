@startuml
title Sueca - Sequência: Jogar Carta (Command + Strategy + Observer)

actor "Player" as P
boundary "GraphQL API" as GQL
control "CommandHandler" as CH
control "GameService" as GS
entity "Game (Domain)" as Game
control "State" as State
control "TrickRuleStrategy" as Rule
control "ScoringStrategy" as Score
control "EventBus" as Bus
boundary "WebSocket Gateway" as WS
control "LoggerObserver" as Log
database "EventStore" as ES

P -> GQL : mutation playCard(gameId, cardId)
GQL -> CH : PlayCardCommand(gameId, playerId, cardId)

CH -> GS : handle(PlayCardCommand)
GS -> Game : PlayCard(playerId, cardId)

Game -> State : validatePlayAllowed()
State --> Game : ok

Game -> Rule : ValidatePlay(hand, leadSuit, card)
Rule --> Game : ok

Game -> Game : removeCardFromHand()\naddPlayToTrick()
Game -> Bus : Publish(CardPlayed)

Bus -> WS : notify(CardPlayed)
Bus -> Log : OnEvent(CardPlayed)
Bus -> ES : Append(CardPlayed)

alt trick has 4 plays
  Game -> Rule : Winner(trumpSuit, plays)
  Rule --> Game : winnerId

  Game -> Score : TrickPoints(plays)
  Score --> Game : points

  Game -> Game : addPointsToWinnerTeam(points)\nTricksPlayed++
  Game -> Bus : Publish(TrickEnded)\nPublish(ScoreUpdated)

  Bus -> WS : notify(TrickEnded, ScoreUpdated)
  Bus -> Log : OnEvent(TrickEnded, ScoreUpdated)
  Bus -> ES : Append(TrickEnded)\nAppend(ScoreUpdated)

  alt TricksPlayed == 10
    Game -> Bus : Publish(GameEnded)
    Bus -> WS : notify(GameEnded)
    Bus -> Log : OnEvent(GameEnded)
    Bus -> ES : Append(GameEnded)
  end
else trick not finished
  Game -> Game : advanceTurn()
  Game -> Bus : Publish(TurnChanged)
  Bus -> WS : notify(TurnChanged)
  Bus -> Log : OnEvent(TurnChanged)
  Bus -> ES : Append(TurnChanged)
end

GS --> CH : result (success/failure)
CH --> GQL : return Boolean / error
GQL --> P : response

@enduml