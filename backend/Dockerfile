FROM golang:1.25 AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/api ./cmd/api

FROM alpine:3.21

WORKDIR /app

RUN apk add --no-cache ca-certificates && adduser -D appuser

COPY --from=builder /bin/api /app/api

USER appuser

EXPOSE 4000

ENTRYPOINT ["/app/api"]
